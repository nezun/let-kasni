# Minimal admin access. If Supabase Auth is configured, these should match
# a real admin user in Supabase Auth. If Supabase is not configured yet, these
# values are used for the local fallback gate.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Optional provider wiring for the flight lookup adapter.
FLIGHT_PROVIDER_MODE=
FLIGHT_LOOKUP_TIMEOUT_MS=
FLIGHT_PROVIDER_DAILY_LIMIT=50
AVIATION_EDGE_API_KEY=
AERODATABOX_API_KEY=
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com

# Optional analytics wiring.
NEXT_PUBLIC_ANALYTICS_MODE=
ANALYTICS_MODE=
PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional admin email notifications via Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_ADMIN_TO_EMAIL=

# Optional Google Search Console automation.
# Add the service account email as an owner/user for this property in Search Console.
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:letkasni.rs
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PRIVATE_KEY_BASE64=
GOOGLE_OAUTH_CLIENT_CREDENTIALS=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
